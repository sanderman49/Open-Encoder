{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Processor",
  "version": "0.1.0",
  "identifier": "com.videoprocessor.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Video Processor",
        "width": 920,
        "height": 720,
        "minWidth": 700,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ]
  }
}
